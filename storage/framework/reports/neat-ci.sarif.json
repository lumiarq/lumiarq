{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "lumis-neat",
          "informationUri": "https://lumiarq.com",
          "rules": [
            {
              "id": "format.file-not-neat",
              "name": "format.file-not-neat"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "format.file-not-neat",
          "level": "error",
          "message": {
            "text": "file is not formatted to LumiARQ conventions"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "config/neat.ts",
                  "uriBaseId": "%SRCROOT%"
                }
              }
            }
          ],
          "properties": {
            "category": "format",
            "autofixable": true,
            "suggestedFix": "Run `lumis neat` to rewrite the file in-place."
          }
        },
        {
          "ruleId": "format.file-not-neat",
          "level": "error",
          "message": {
            "text": "file is not formatted to LumiARQ conventions"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/modules/Docs/ui/web/templates/docs-page.veil.html",
                  "uriBaseId": "%SRCROOT%"
                }
              }
            }
          ],
          "properties": {
            "category": "format",
            "autofixable": true,
            "suggestedFix": "Run `lumis neat` to rewrite the file in-place."
          }
        },
        {
          "ruleId": "format.file-not-neat",
          "level": "error",
          "message": {
            "text": "file is not formatted to LumiARQ conventions"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/modules/Docs/ui/web/templates/docs-unavailable-page.veil.html",
                  "uriBaseId": "%SRCROOT%"
                }
              }
            }
          ],
          "properties": {
            "category": "format",
            "autofixable": true,
            "suggestedFix": "Run `lumis neat` to rewrite the file in-place."
          }
        }
      ]
    }
  ]
}