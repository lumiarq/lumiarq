{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/bootstrap/*": ["./bootstrap/*"],
      "@/storage/*": ["./src/storage/*"],
      "@/config/*": ["./src/config/*"],
      "@/tests/*": ["./src/tests/*"],
      "@/lang/*": ["./src/lang/*"]
    },
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src", "src/modules", "src/shared", "bootstrap"],
  "exclude": ["node_modules", "dist"]
}
